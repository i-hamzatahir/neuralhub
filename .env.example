# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=hello@neuralhub.blog
NEXT_PUBLIC_APP_NAME=NeuralHub
# Personal blog mode (default on): no public sign-up, owner publishes via /dashboard
NEXT_PUBLIC_PERSONAL_SITE=true
NODE_ENV=development

# Set on Vercel automatically; add locally only if testing proxy IP behavior
# TRUST_PROXY=true

# ─── Database (Neon PostgreSQL — free tier) ───────────────────────────────────
# IMPORTANT: Prisma migrations require a DIRECT connection.
#
# In Neon dashboard, copy the connection string WITHOUT "-pooler" in the host:
#   ✅ ep-xxx-xxx.region.aws.neon.tech
#   ❌ ep-xxx-xxx-pooler.region.aws.neon.tech  (pooler — optional for runtime)
#
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neuralhub?sslmode=require"
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neuralhub?sslmode=require"

# ─── Auth (Auth.js) ──────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Production with www primary domain (e.g. Vercel redirects apex → www):
# AUTH_URL=https://www.neuralhub.blog
# NEXT_PUBLIC_APP_URL=https://www.neuralhub.blog
# NEXT_PUBLIC_FORCE_WWW=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Storage (Supabase — required in production) ─────────────────────────────
# Free tier: 1 GB storage. Create a public "media" bucket.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend — free tier: 3,000 emails/month) ──────────────────────────
RESEND_API_KEY=
EMAIL_FROM=NeuralHub <noreply@yourdomain.com>

# Dev-only Gmail SMTP fallback (not wired — Resend preferred)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Analytics & monitoring (all optional, free tiers available) ─────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_TWITTER_HANDLE=@neuralhub
NEXT_PUBLIC_CLARITY_PROJECT_ID=
GOOGLE_SITE_VERIFICATION=

# ─── Ads (disabled by default) ───────────────────────────────────────────────
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=

# ─── AI (disabled by default — costs money when enabled) ─────────────────────
AI_ENABLED=false
AI_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Search ──────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=postgres-fts

# ─── Cron (required in production) ─────────────────────────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET=

# Optional — on-demand ISR revalidation only (not used for cron auth)
REVALIDATION_SECRET=
